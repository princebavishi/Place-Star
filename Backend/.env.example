# ─── Backend .env example ─────────────────────────────────────────────────────
# Copy this file to .env and fill in real values for local dev.
# In Railway/Docker production, set these as environment variables directly.

PORT=3000
NODE_ENV=production

# JWT — use a long random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_me_to_a_long_random_secret

# SQLite DB path
# Locally: leave blank → uses Backend/database.sqlite
# Docker/Railway: set to /data/database.sqlite (mounted volume)
DB_PATH=

# Comma-separated list of allowed CORS origins (no trailing slash)
# Example: https://placestar.up.railway.app,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Nodemailer SMTP — use Gmail with an App Password
EMAIL_SERVICE=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
